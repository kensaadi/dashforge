{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "dashforge-web",
  "sourceRoot": "web/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "web",
        "command": "vite build"
      },
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"]
    }
  }
}
