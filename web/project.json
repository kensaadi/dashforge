{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "dashforge-web",
  "sourceRoot": "web/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "web",
        "commands": ["vite build", "npm run prerender", "npm run sitemap"],
        "parallel": false
      },
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "production",
        "^production",
        "{projectRoot}/scripts/prerender.ts",
        "{projectRoot}/scripts/generate-sitemap.ts",
        "{projectRoot}/scripts/generate-routes.ts"
      ],
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/dist/sitemap.xml",
        "{projectRoot}/dist/index.html",
        "{projectRoot}/dist/components/index.html",
        "{projectRoot}/dist/pricing/index.html",
        "{projectRoot}/dist/starter-kits/*/index.html",
        "{projectRoot}/dist/docs/**/index.html"
      ]
    }
  }
}
