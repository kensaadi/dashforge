{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  // No `references` block intentional — without it, the TS bundler
  // resolver picks up the workspace `src/index.ts` of each peer
  // through the path mapping in `tsconfig.base.json`, which is the
  // canonical source-of-truth. With references, TS preferred each
  // dep's `dist/index.d.ts` wrapper (`export * from "./src/index"`)
  // and the chain ambient-re-export through that wrapper silently
  // dropped re-exports under `bundler` module resolution. The build
  // chain still runs the deps' `build` targets before this one via
  // `dependsOn: ["typecheck", "^build"]` so `nx` order is preserved.
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ],
  "references": [
    {
      "path": "../ui-core/tsconfig.lib.json"
    },
    {
      "path": "../rbac/tsconfig.lib.json"
    },
    {
      "path": "../forms/tsconfig.lib.json"
    },
    {
      "path": "../calendar-core/tsconfig.lib.json"
    },
    {
      "path": "../tw-tokens/tsconfig.lib.json"
    },
    {
      "path": "../tw-theme/tsconfig.lib.json"
    }
  ]
}
