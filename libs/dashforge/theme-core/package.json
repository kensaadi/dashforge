{
  "name": "@dashforge/theme-core",
  "version": "1.0.0",
  "description": "Core theming system for Dashforge",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@dashforge/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@dashforge/tokens": "workspace:*",
    "tslib": "^2.3.0",
    "valtio": "^2.3.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "dashforge",
    "theme",
    "theming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kensaadi/dashforge.git",
    "directory": "libs/dashforge/theme-core"
  },
  "homepage": "https://github.com/kensaadi/dashforge/tree/main/libs/dashforge/theme-core",
  "bugs": {
    "url": "https://github.com/kensaadi/dashforge/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
